# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Frontend (used for CORS allowlist in production)
FRONTEND_URL=http://localhost:5173

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
MAIL_MAILER=smtp
MAIL_FROM_NAME=Your name
MAIL_FROM_ADDRESS=app@yourdomain.com
SMTP_HOST=localhost
SMTP_PORT=1025
LIMITER_STORE=database

#--------------------------------------------------------------------
# ML microservice (Python FastAPI yield prediction)
#--------------------------------------------------------------------
ML_SERVICE_URL=http://localhost:8000
#--------------------------------------------------------------------
# Anthropic API – RAG Intelligent Query System
# Get your key at: https://console.anthropic.com/
#--------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

#--------------------------------------------------------------------
# Cerebras API – RAG Intelligent Query System (alternative provider)
#--------------------------------------------------------------------
CEREBRAS_API_KEY=cs-...
# CEREBRAS_MODEL=llama3.1-70b
# CEREBRAS_API_URL=https://api.cerebras.ai/v1/chat/completions

#--------------------------------------------------------------------
# Chapa Payment Gateway (Ethiopian payment processor)
# Get your key at: https://dashboard.chapa.co/
#--------------------------------------------------------------------
CHAPA_SECRET_KEY=CHAPASK-...
